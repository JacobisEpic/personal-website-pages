Options -MultiViews
DirectoryIndex index.html

<IfModule mod_rewrite.c>
  RewriteEngine On

  RewriteRule ^(support|privacy|terms)/?$ $1.html [L]

  RewriteCond %{THE_REQUEST} \s/+(.*/)?timemaxx/index\.html(?:[\s?]|$) [NC]
  RewriteRule ^index\.html$ ./ [R=301,L]

  RewriteCond %{THE_REQUEST} \s/+(.*/)?timemaxx/(support|privacy|terms)\.html(?:[\s?]|$) [NC]
  RewriteRule ^(support|privacy|terms)\.html$ $1 [R=301,L]
</IfModule>
